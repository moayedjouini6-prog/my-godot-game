[sub_resource type="GDScript" id="GDScript_ig7tw"]
script/source = "extends CharacterBody3D

# --- Movement Settings ---
@export var SPEED : float = 5.0
@export var JUMP_VELOCITY : float = 4.5
@export var MOUSE_SENSITIVITY : float = 0.003
const main_menu = \"res://main_menu.tscn\"

# --- References ---
@onready var camera: Camera3D = $head/Camera3D
@onready var gun: Node3D = $head/Camera3D/gun

# ربط نود الـ HP الصحيحة من الـ CanvasLayer2 بناءً على صورتك
@onready var hp_label: Label = $CanvasLayer2/HPLable

# --- Health Settings ---
@export var max_hp: int = 3
var current_hp: int = max_hp

# Get the gravity from the project settings to be sync'd with RigidBody nodes.
var gravity: float = ProjectSettings.get_setting(\"physics/3d/default_gravity\")


func _ready() -> void:
	Input.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)
	current_hp = max_hp
	update_hp_ui()

func _unhandled_input(event: InputEvent) -> void:
	# Handle Mouse Look
	if event is InputEventMouseMotion and Input.get_mouse_mode() == Input.MOUSE_MODE_CAPTURED:
		rotate_y(-event.relative.x * MOUSE_SENSITIVITY)
		camera.rotate_x(-event.relative.y * MOUSE_SENSITIVITY)
		camera.rotation.x = clamp(camera.rotation.x, deg_to_rad(-89), deg_to_rad(89))

func _physics_process(delta: float) -> void:
	# Add the gravity.
	if not is_on_floor():
		velocity.y -= gravity * delta

	# Handle jump.
	if Input.is_action_just_pressed(\"ui_accept\") and is_on_floor():
		velocity.y = JUMP_VELOCITY

	# Get the input direction and handle the movement/deceleration.
	var input_dir := Input.get_vector(\"ui_left\", \"ui_right\", \"ui_up\", \"ui_down\")
	
	var direction := (transform.basis * Vector3(input_dir.x, 0, input_dir.y)).normalized()
	if direction:
		velocity.x = direction.x * SPEED
		velocity.z = direction.z * SPEED
	else:
		velocity.x = move_toward(velocity.x, 0, SPEED)
		velocity.z = move_toward(velocity.z, 0, SPEED)

	move_and_slide()
	
	# --- الموت عند السقوط في الفراغ ---
	if global_position.y < -20.0:
		die()
	
	# --- Shooting Input ---
	if Input.is_action_just_pressed(\"shoot\") or Input.is_mouse_button_pressed(MOUSE_BUTTON_LEFT):
		if gun and gun.has_method(\"shoot\"):
			gun.shoot()

# --- Health Functions ---

func take_damage(amount: int) -> void:
	current_hp -= amount
	update_hp_ui()
	
	if current_hp <= 0:
		# استدعاء آمن للموت لتفادي خطأ الـ CollisionObject في الـ Debugger
		callable_num_tickets()

func callable_num_tickets():
	call_deferred(\"die\")

func update_hp_ui() -> void:
	if hp_label:
		hp_label.text = \"HP: \" + str(current_hp) + \" / \" + str(max_hp)

func die() -> void:
	print(\"اللاعب مات!\")
	get_tree().reload_current_scene() # إعادة تشغيل المرحلة الحالية بأمان
"

